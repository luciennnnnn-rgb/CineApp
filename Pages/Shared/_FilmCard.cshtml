@model CineApp.Models.Film

<div class="card h-100">
    <div class="card-body d-flex flex-column">
        <h5 class="card-title">@Model.Titre</h5>
        <p class="card-text">
            <span style="color: #e50914;">@Model.GenreNom</span> · @Model.AnneeSortie
        </p>
        <p class="card-text flex-grow-1">@Model.Description</p>
        <a href="/Details/@Model.Id" class="btn btn-primary mt-2">Voir détails</a>
    </div>
</div>