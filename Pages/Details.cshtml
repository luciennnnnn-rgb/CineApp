@page "/Details/{id:int}"
@model CineApp.Pages.DetailsModel
@{
    ViewData["Title"] = Model.Film?.Titre ?? "Film introuvable";
}

@if (Model.Film is null)
{
    <p>Film introuvable.</p>
}
else
{
    <div class="mb-4 p-4 rounded" style="background-color: #1e2a3a;">
        <div class="row">
            <div class="col-md-8">
                <h1>@Model.Film.Titre</h1>
                <p>
                    <span style="color: #4f8ef7;">@Model.Film.GenreNom</span>
                    <span class="text-muted mx-2">·</span>
                    <span class="text-muted">@Model.Film.AnneeSortie</span>
                </p>
                <p class="lead">@Model.Film.Description</p>
                <a href="/" class="btn btn-secondary">← Retour</a>
            </div>
        </div>
    </div>

    <div class="mt-5">
        <h3 class="mb-4">💬 Commentaires
            <span class="fs-6 text-muted ms-2">(@Model.Commentaires.Count avis)</span>
        </h3>

        @if (User.Identity!.IsAuthenticated)
        {
            <div class="p-4 rounded mb-4" style="background-color: #1e2a3a;">
                <h5>Laisser un avis</h5>
                <form method="post">
                    <input type="hidden" name="FilmId" value="@Model.Film.Id" />
                    <div class="mb-3">
                        <label class="form-label">Votre commentaire</label>
                        <textarea class="form-control" name="Contenu" rows="3" placeholder="Donnez votre avis..."></textarea>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Note</label>
                        <select class="form-control w-auto" name="Note">
                            <option value="1">⭐ 1</option>
                            <option value="2">⭐⭐ 2</option>
                            <option value="3">⭐⭐⭐ 3</option>
                            <option value="4">⭐⭐⭐⭐ 4</option>
                            <option value="5">⭐⭐⭐⭐⭐ 5</option>
                        </select>
                    </div>
                    <button type="submit" class="btn btn-primary">Publier</button>
                </form>
            </div>
        }
        else
        {
            <div class="p-4 rounded mb-4 text-center" style="background-color: #1e2a3a;">
                <p class="mb-2">Vous souhaitez donner votre avis ?</p>
                <a href="/Login" class="btn btn-primary">Se connecter</a>
                <a href="/Register" class="btn btn-secondary ms-2">S'inscrire</a>
            </div>
        }

        @if (!Model.Commentaires.Any())
        {
            <div class="p-4 rounded text-center" style="background-color: #1e2a3a;">
                <p class="text-muted mb-0">Aucun commentaire pour ce film. Soyez le premier !</p>
            </div>
        }
        else
        {
            @foreach (var c in Model.Commentaires)
            {
                <div class="card mb-3">
                    <div class="card-body">
                        <div class="d-flex justify-content-between mb-2">
                            <span style="color: #4f8ef7;">@c.UserNom</span>
                            <span class="text-muted">@c.DatePublication.ToString("dd/MM/yyyy")</span>
                        </div>
                        <p class="mb-1">@string.Concat(Enumerable.Repeat("⭐", c.Note))</p>
                        <p class="card-text">@c.Contenu</p>
                        @if (User.IsInRole("admin"))
                        {
                            <form method="post" asp-page-handler="DeleteComment">
                                <input type="hidden" name="commentaireId" value="@c.Id" />
                                <input type="hidden" name="filmId" value="@Model.Film.Id" />
                                <button type="submit" class="btn btn-danger btn-sm mt-2">Supprimer</button>
                            </form>
                        }
                    </div>
                </div>
            }
        }
    </div>
}