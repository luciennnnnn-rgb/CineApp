@page
@model CineApp.Pages.IndexModel
@{
    ViewData["Title"] = "Films";
}

<div class="text-center py-5 mb-4" style="background: linear-gradient(180deg, #1e2a3a, #111827); border-radius: 12px;">
    <h1 class="display-4 fw-bold" style="color: #4f8ef7;">🎬 CineApp</h1>
    <p class="lead" style="color: #aaaaaa;">Découvrez les meilleurs films du moment</p>
</div>

<form method="get" class="mb-4">
    <div class="d-flex gap-2">
        <select name="GenreId" class="form-control w-auto">
            <option value="">Tous les genres</option>
            @foreach (var genre in Model.Genres)
            {
                <option value="@genre.Id" selected="@(Model.GenreId == genre.Id)">
                    @genre.Nom
                </option>
            }
        </select>
        <button type="submit" class="btn btn-primary">Filtrer</button>
        <a href="/" class="btn btn-secondary">Réinitialiser</a>
    </div>
</form>

@if (!Model.Films.Any())
{
    <p class="text-muted">Aucun film disponible pour ce genre.</p>
}
else
{
    <div class="row">
        @foreach (var film in Model.Films)
        {
            <div class="col-md-4 mb-4">
                <partial name="_FilmCard" model="film" />
            </div>
        }
    </div>
}