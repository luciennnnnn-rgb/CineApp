@page
@model CineApp.Pages.Admin.Films.IndexModel
@{
    ViewData["Title"] = "Administration - Films";
}

<h1>Gestion des films</h1>

<a href="/Admin/Films/Create" class="btn btn-success mb-3">+ Ajouter un film</a>

<table class="table">
    <thead>
    <tr>
        <th>Titre</th>
        <th>Genre</th>
        <th>Année</th>
        <th>Actions</th>
    </tr>
    </thead>
    <tbody>
    @foreach (var film in Model.Films)
    {
        <tr>
            <td>@film.Titre</td>
            <td>@film.GenreNom</td>
            <td>@film.AnneeSortie</td>
            <td>
                <a href="/Admin/Films/Edit/@film.Id" class="btn btn-warning btn-sm">Modifier</a>
                <form method="post" style="display:inline">
                    <input type="hidden" name="id" value="@film.Id" />
                    <button type="submit" class="btn btn-danger btn-sm">Supprimer</button>
                </form>
            </td>
        </tr>
    }
    </tbody>
</table>